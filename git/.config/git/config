[alias]
  bare-clone = !git_bare_clone
  branch-name = !git rev-parse --abbrev-ref HEAD
  default-branch = !awk -F'/' '{print $NF}' .git/refs/remotes/origin/HEAD

  excluded = ls-files --ignored --others --exclude-from=.git/info/exclude
  ignored = !git status -s --ignored | rg '^!!\\s*' -r '' | sort

  publish = !git push -u origin $(git branch-name)
  unpublish = !git push origin :$(git branch-name)

  files-changed = !git diff --name-only $(git merge-base HEAD $(git default-branch))
  diff-main = !git diff $(git merge-base HEAD $(git default-branch))
  review = "!f() { $EDITOR ${@:-$(git files-changed)}; }; f"
  stat = !git diff --stat $(git merge-base HEAD $(git default-branch))
[branch]
  sort = -committerdate
[color]
  ui = auto
[column]
  ui = auto
[commit]
  verbose = true
[core]
  autocrlf = input
  excludesfile = ~/.config/git/global_gitignore
  # For big repositories
  ; fsmonitor = true
  ; untrackedCache = true
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
  tool = nvimdiff
[difftool]
  prompt = false
  keepBackup = false
[fetch]
  all = true
  prune = true
  pruneTags = true
[help]
  autocorrect = prompt
[init]
  defaultBranch = main
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[filter "media"]
  clean = git media clean %f
  smudge = git media smudge %f
  required = true
[merge]
  conflictstyle = diff3
  ff = false
[mergetool]
  prompt = false
  keepBackup = false
[pull]
  rebase = true
[push]
  autoSetupRemote = true
  default = simple
  followTags = true
  recurseSubmodules = on-demand
[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true
[tag]
  sort = version:refname
[user]
  name = David Marchante
  email = notdavid@meraki.com
[submodule]
  recurse = true
