#!/usr/bin/env bash

fzf_command() {
  fzf \
    --prompt="❯ " \
    --gutter=" " \
    --info=hidden \
    --highlight-line \
    --reverse \
    --bind="j:down,k:up,q:abort" \
    --no-preview
}

action=$(printf "suspend\nshutdown\nreboot\nlogout" | fzf_command) || exit 0

case $action in
"logout") hyprshutdown -t "logout" ;;
"reboot") hyprshutdown -t "reboot" --post-cmd "systemctl reboot" ;;
"shutdown") hyprshutdown -t "shutdown" --post-cmd "systemctl poweroff" ;;
"suspend") systemctl suspend ;;
esac
