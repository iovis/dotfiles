#!/usr/bin/env bash

set -euo pipefail

pane_id="${1:-$(tmux display -p '#{pane_id}')}"

# Capture full scrollback + visible content with ANSI color escapes to a temp
# file. We omit -J so each line maps 1:1 to a screen row in copy mode.
captured=$(mktemp)
numbered=$(mktemp)
trap 'rm -f "$captured" "$numbered"' EXIT

tmux capture-pane -ep -S - -t "$pane_id" >"$captured"

# Prepend line numbers (tab-separated). Tabs don't appear in ANSI sequences,
# so they're a safe field delimiter for fzf.
awk '{printf "%d\t%s\n", NR, $0}' "$captured" >"$numbered"

# --tac reverses input so newest lines come first (nearest the bottom prompt).
# --layout=default puts the prompt at the bottom with the cursor there, so the
# visual result is: oldest content at the top, newest just above the prompt,
# cursor on the bottom line — mimicking the original pane.
# --bind result:best jumps to the best match as you type.
# --bind alt-l inserts a prompt filter to quickly jump between shell prompts.
result=$(fzf \
  --no-multi \
  --raw \
  --ansi \
  --tac \
  --delimiter='\t' \
  --with-nth='2..' \
  --layout=default \
  --no-scrollbar \
  --no-separator \
  --no-sort \
  --prompt='❯ ' \
  --color='prompt:5' \
  --info=inline-right \
  --bind='result:best' \
  --bind='alt-l:change-query(^❯ )' \
  --bind='alt-r:toggle-raw' \
  <"$numbered") || exit 0

# Extract the line number from the selected entry.
line_num=$(cut -f1 <<<"$result")

if [[ -z "$line_num" ]]; then
  exit 0
fi

# Navigate to the selected line in copy mode. We use history-bottom to place the
# cursor on the last line (oy=0), then cursor-up N times to reach the target.
# This correctly handles both scrollback and visible-area lines, unlike goto-line
# which only sets the scroll offset without moving the cursor.
history_size=$(tmux display -p -t "$pane_id" '#{history_size}')
pane_height=$(tmux display -p -t "$pane_id" '#{pane_height}')
total=$((history_size + pane_height))
lines_up=$((total - line_num))

tmux copy-mode -t "$pane_id"
tmux send-keys -t "$pane_id" -X history-bottom
if [[ "$lines_up" -gt 0 ]]; then
  tmux send-keys -t "$pane_id" -X -N "$lines_up" cursor-up
fi
tmux send-keys -t "$pane_id" -X scroll-middle
tmux send-keys -t "$pane_id" -X select-line
